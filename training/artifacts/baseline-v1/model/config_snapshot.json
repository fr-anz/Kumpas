{
  "version": "baseline-v1",
  "random_seed": 42,
  "paths": {
    "labels_csv": "labels.csv",
    "train_csv": "train.csv",
    "test_csv": "test.csv",
    "video_base": "clips",
    "hand_landmarker_model": "models/hand_landmarker.task",
    "cache_dir": "cache/baseline-v1",
    "artifact_dir": "artifacts/baseline-v1"
  },
  "labels": [
    "YES",
    "NO",
    "DEAF",
    "THANK YOU",
    "SLOW",
    "DON’T UNDERSTAND"
  ],
  "sequence_length": 40,
  "feature_count": 128,
  "temporal_crop": {
    "start_ratio": 0.15,
    "end_ratio": 0.85
  },
  "split_ratios": {
    "train": 0.7,
    "validation": 0.15,
    "test": 0.15
  },
  "hand_landmarker": {
    "num_hands": 2,
    "min_hand_detection_confidence": 0.4,
    "min_hand_presence_confidence": 0.4,
    "min_tracking_confidence": 0.4
  },
  "training": {
    "epochs": 100,
    "batch_size": 16,
    "learning_rate": 0.001,
    "early_stopping_patience": 15
  }
}