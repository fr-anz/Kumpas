# Copy this file to .env and fill in your values.

# ElevenLabs API key — used ONLY for Filipino text-to-speech.
# WARNING: This app is a static export (no server). Any NEXT_PUBLIC_ value is
# embedded in the client bundle and visible to end users. Use for local
# development / demos only; do not ship a real key in a public deployment.
NEXT_PUBLIC_ELEVENLABS_API_KEY=

# Optional ElevenLabs voice id for Filipino speech (multilingual voice).
NEXT_PUBLIC_ELEVENLABS_VOICE_ID=
